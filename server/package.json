    "@types/express": "^4.17.21",
    "@types/node": "^20.19.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nodemon": "^3.1.10",
