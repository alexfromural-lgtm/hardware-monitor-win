# ── Collector (runs natively on Windows host, outside Docker) ─────────────────
COLLECTOR_PORT=5390

# ── GraphQL Server (runs in Docker) ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# URL of the collector as seen from inside Docker
# host.docker.internal resolves to the Windows host from inside a Linux container
COLLECTOR_URL=http://host.docker.internal:5390

# How often (ms) the GraphQL server polls the collector
POLL_INTERVAL_MS=2000

# CORS origin for the future UI
CORS_ORIGIN=http://localhost:5173
